# ==========================================
# SECUREVOTE — ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ==========================================


# ==========================================
# CORE SETTINGS (required)
# ==========================================

NODE_ENV=development        # development | production
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
EMERGENCY_PASSWORD=change-this-to-a-secure-emergency-password


# ==========================================
# EMAIL PROVIDER
# ==========================================
# Set EMAIL_PROVIDER to one of:
#
#   resend    ← RECOMMENDED — free tier covers most elections (see below)
#   smtp      — any standard SMTP server (Mailgun, Postmark, Brevo, self-hosted)
#   sendgrid  — SendGrid via SMTP relay
#   ses       — Amazon SES via SMTP (cheapest at scale)
#   console   — logs emails to terminal only, nothing sent (default for dev/test)
#
# During local development: leave EMAIL_PROVIDER=console
# For a live election:       set EMAIL_PROVIDER=resend (or your preferred provider)

EMAIL_PROVIDER=console

# Displayed as the sender name in all outgoing emails
EMAIL_FROM=elections@voterterminal.com
EMAIL_FROM_NAME=SecureVote


# ------------------------------------------
# ✅ RESEND (recommended)
# ------------------------------------------
# Best choice for most SecureVote deployments.
# Free tier: 3,000 emails/month, 100/day — enough for most elections.
# Pro tier ($20/mo): 50,000 emails/month, no daily cap — upgrade before
# large voter roll sends if you need to send 100+ invites in one day.
#
# Setup (2 minutes):
#   1. Sign up at https://resend.com
#   2. Add your sending domain under Domains and add the DNS records it gives you
#      (SPF + DKIM — required for inbox delivery on a new domain)
#   3. Create an API key under API Keys
#   4. Set EMAIL_PROVIDER=resend and fill in below

RESEND_API_KEY=re_your_api_key_here


# ------------------------------------------
# SMTP — generic (any provider)
# ------------------------------------------
# Use this for: Brevo, Mailgun, Postmark, Zoho, self-hosted Postfix, etc.
# Leave blank if using resend / ses above.
#
# Brevo example   (300 emails/day free):  SMTP_HOST=smtp-relay.brevo.com      PORT=587
# Mailgun example (~$0.80/1k emails):     SMTP_HOST=smtp.mailgun.org           PORT=587
# Postmark example ($15/mo for 10k):      SMTP_HOST=smtp.postmarkapp.com       PORT=587

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false           # true = TLS on port 465, false = STARTTLS on 587
SMTP_USER=
SMTP_PASS=


# ------------------------------------------
# SendGrid
# ------------------------------------------
# Free: 100 emails/day forever.
# Get your API key: https://app.sendgrid.com/settings/api_keys
# Set EMAIL_PROVIDER=sendgrid to activate.

SENDGRID_API_KEY=


# ------------------------------------------
# Amazon SES (Simple Email Service)
# ------------------------------------------
# Cost: ~$0.10 per 1,000 emails — best choice for very high volume.
# IMPORTANT: SES SMTP credentials are NOT your IAM Access Key.
#   Generate them at: AWS Console → SES → SMTP settings → Create SMTP credentials
# Set EMAIL_PROVIDER=ses to activate.

SES_SMTP_USER=
SES_SMTP_PASS=
SES_REGION=us-east-1


# ==========================================
# ADMIN CREDENTIALS (single-tenant mode)
# ==========================================
# These set the default admin account on first startup.
# Change them here, then restart pm2 to take effect.
# Better long-term: change password via /admin → Settings.

ADMIN_EMAIL=admin@voting.com
ADMIN_PASSWORD=changeme123

# ==========================================
# ORG BRANDING (single-tenant mode)
# ==========================================
ORG_NAME=My Organization
ORG_TAGLINE=Official Ballot
ORG_BANNER_COLOR=#003087
ORG_LOGO_URL=

# ==========================================
# MULTI-TENANT / SaaS MODE (tenant-server.js)
# ==========================================
# Set BASE_DOMAIN to your root domain.
# Tenants are served at {subdomain}.BASE_DOMAIN.
# Superadmin credentials control the /api/superadmin/* endpoints.

BASE_DOMAIN=voterterminal.com
SUPERADMIN_EMAIL=super@voterterminal.com
SUPERADMIN_PASSWORD=change-this-immediately

# ==========================================
# STRIPE (SaaS billing — optional)
# ==========================================
# Required only when running tenant-server.js with paid plans.
# Get keys at https://dashboard.stripe.com/apikeys
#
# Setup:
#   1. Create products + prices in the Stripe dashboard for each plan
#   2. Copy the Price IDs (price_xxx) into the variables below
#   3. Set up a webhook endpoint pointing to /api/stripe/webhook
#   4. Copy the webhook signing secret into STRIPE_WEBHOOK_SECRET

STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs for each plan (from Stripe dashboard)
STRIPE_PRICE_STARTER=price_xxx_starter
STRIPE_PRICE_PRO=price_xxx_pro

# ==========================================
# DNS RECORDS — required for inbox delivery
# ==========================================
# Regardless of provider, add these DNS records to your sending domain.
# Every provider's dashboard will give you the exact values to paste in.
#
#   SPF   — tells receiving servers your provider is allowed to send for your domain
#   DKIM  — cryptographic signature proving emails weren't tampered with
#   DMARC — policy for what to do with emails that fail SPF/DKIM (optional but recommended)
#
# Without SPF + DKIM, emails from a new domain will land in spam.
# ==========================================
